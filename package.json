{
  "name": "readmark",
  "displayName": "ReadMark",
  "description": "Help beginner to read github project",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "readmark.toggleRead",
        "title": "标记为已读",
        "icon": "$(check)" 
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "readmark.toggleRead",
          "when": "resourceScheme == file",
          "group": "navigation"
        }
      ]
    },
    
    "colors": [
      {
        "id": "readmark.doneForeground",
        "description": "已读文件的颜色",
        "defaults": {
          "dark": "#808080",
          "light": "#808080"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
